<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:src="@drawable/ic_terminal"
            android:contentDescription="Termux" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Termux Required"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ClaudeCode needs Termux to run Claude Code on your Android device.\n\nTermux provides the Linux environment required to run Claude Code on ARM devices."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:background="@drawable/bg_provider_card"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How to install:"
                android:textColor="@color/accent_orange"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Tap the button below to open Termux on F-Droid\n\n2. Install Termux from F-Droid (not the Play Store version)\n\n3. Come back here and tap Check"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Note: Use the F-Droid version — the Play Store version is outdated."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="italic" />

        </LinearLayout>

        <Button
            android:id="@+id/btnOpenFdroid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Get Termux on F-Droid"
            android:textSize="16sp"
            android:backgroundTint="@color/accent_orange" />

        <Button
            android:id="@+id/btnCheckInstalled"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="I already installed Termux"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</ScrollView>
