<?xml version="1.0" encoding="utf-8"?>
<!--
  Convergence Gate — foreground layer for adaptive icon (108×108dp, 72dp safe zone).
  Diamond outline + 4 lines converging to amber center node.
  viewBox 108×108, center (54,54), tips: top(54,8) right(100,54) bottom(54,100) left(8,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Diamond outline -->
    <path
        android:pathData="M54,8 L100,54 L54,100 L8,54 Z"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E8834A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Converging lines: top tip → center -->
    <path android:pathData="M54,8 L54,54"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E8834A"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Right tip → center -->
    <path android:pathData="M100,54 L54,54"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E8834A"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Bottom tip → center -->
    <path android:pathData="M54,100 L54,54"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E8834A"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Left tip → center -->
    <path android:pathData="M8,54 L54,54"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E8834A"
        android:strokeWidth="1.8"
        android:strokeLineCap="round" />

    <!-- Amber center node (filled circle) -->
    <path android:pathData="M54,54m-8,0a8,8 0 1,0 16,0a8,8 0 1,0 -16,0"
        android:fillColor="#E8834A" />

    <!-- Subtle inner glow ring -->
    <path android:pathData="M54,54m-12,0a12,12 0 1,0 24,0a12,12 0 1,0 -24,0"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E8834A40"
        android:strokeWidth="1.2" />

</vector>
